{
  "name": "se-disaster-starter",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "description": "SITCON Camp 2026 software engineering workshop starter for disaster information components.",
  "license": "MIT",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:data": "tsx scripts/validate-fixtures.ts",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run validate:data && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "typescript": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "24",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "prettier": "latest",
    "tsx": "latest",
    "vitest": "latest",
    "typescript-eslint": "latest"
  }
}
